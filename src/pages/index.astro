---
import SiteLayout from '../layouts/SiteLayout.astro';
import { tools } from '../data/tools';
import { getAllPosts } from '../utils/posts';

const posts = await getAllPosts();
const latestPosts = posts.slice(0, 3);
---

<SiteLayout
  title="RustZen | Zen Clear and Clipboard"
  description="RustZen builds native macOS client apps for developer disk cleanup and local clipboard history."
>
  <main>
    <section class="hero">
      <img
        class="hero-image"
        src="/rustzen-macos-suite.png"
        alt="Zen Clear and Clipboard native macOS client windows"
      />
      <div class="hero-copy reveal">
        <p class="eyebrow">Native macOS client apps</p>
        <h1>RustZen for local developer work.</h1>
        <p>
          Zen Clear and Clipboard are separate macOS clients with one
          shared product language: local-first, explicit, inspectable, and built
          for daily developer workflows.
        </p>
        <div class="button-row">
          <a class="button primary" href="/zen-clear">Explore Clear</a>
          <a class="button secondary" href="/clipboard">Explore Clipboard</a>
        </div>
      </div>
    </section>

    <section class="tools-section" aria-labelledby="tools-title">
      <div class="section-heading">
        <p class="eyebrow">Zen Clear / Clipboard</p>
        <h2 id="tools-title">Two native clients, one RustZen system.</h2>
      </div>
      <div class="tool-lines">
        {
          tools.map((tool) => (
            <a class={`tool-line ${tool.accent}`} href={tool.href}>
              <div>
                <p class="tool-status">{tool.status}</p>
                <h3>{tool.name}</h3>
                <p>{tool.description}</p>
              </div>
              <span aria-hidden="true">View</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="principle-section">
      <div>
        <p class="eyebrow">Product principle</p>
        <h2>Native windows. Local data. Explicit actions.</h2>
      </div>
      <p>
        Zen Clear explains every cleanup candidate before deletion. Clipboard keeps
        history searchable on the Mac. Cloud only supports licensing, versions,
        and releases; it does not become the runtime for private local data.
      </p>
    </section>

    <section class="blog-strip" aria-labelledby="blog-title">
      <div class="section-heading">
        <p class="eyebrow">Blog</p>
        <h2 id="blog-title">Development notes and product updates.</h2>
      </div>
      <div class="latest-posts">
        {
          latestPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="latest-post">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </a>
          ))
        }
      </div>
      <a class="button secondary" href="/blog">Read blog</a>
    </section>
  </main>
</SiteLayout>

<style>
  .hero {
    position: relative;
    min-height: clamp(480px, calc(100svh - 220px), 560px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: #121821;
    color: var(--charcoal);
  }

  .hero::after {
    position: absolute;
    inset: 0;
    content: '';
    background:
      linear-gradient(90deg, rgb(12 17 24 / 0.82) 0%, rgb(12 17 24 / 0.48) 38%, transparent 72%),
      linear-gradient(180deg, transparent 0%, rgb(12 17 24 / 0.34) 76%, rgb(12 17 24 / 0.84) 100%);
    pointer-events: none;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% 48%;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    width: min(760px, 100%);
    padding: clamp(30px, 5vw, 54px) clamp(22px, 5vw, 72px);
    color: #ffffff;
  }

  .hero h1 {
    max-width: 11ch;
    margin: 0;
    font-size: clamp(2.5rem, 5vw, 4.25rem);
    line-height: 0.94;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .hero-copy > p:not(.eyebrow) {
    max-width: 560px;
    margin: 18px 0 22px;
    color: rgb(244 247 251 / 0.82);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .hero .eyebrow {
    color: #8ddbd4;
  }

  .hero .button.primary {
    color: #ffffff;
    background: linear-gradient(135deg, var(--clipboard-teal), #168c83);
  }

  .hero .button.secondary {
    color: #ffffff;
    background: rgb(255 255 255 / 0.1);
    border-color: rgb(255 255 255 / 0.32);
    backdrop-filter: blur(12px);
  }

  .tools-section,
  .blog-strip {
    padding: clamp(64px, 10vw, 124px) clamp(20px, 5vw, 72px);
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 34px;
  }

  .section-heading h2,
  .principle-section h2 {
    margin: 0;
    color: var(--charcoal);
    font-size: clamp(2.1rem, 5vw, 4.4rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .tool-lines {
    display: grid;
    gap: 1px;
    background: rgb(100 112 134 / 0.16);
  }

  .tool-line {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: center;
    min-height: 220px;
    padding: clamp(24px, 5vw, 54px);
    background: rgb(255 255 255 / 0.74);
    transition:
      background 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease;
  }

  .tool-line:hover {
    background: rgb(255 255 255 / 0.94);
    box-shadow: 0 16px 42px rgb(96 112 138 / 0.12);
  }

  .tool-status {
    margin: 0 0 16px;
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .tool-line.clear .tool-status {
    color: #4c8de9;
  }

  .tool-line.clipboard .tool-status {
    color: var(--clipboard-teal);
  }

  .tool-line h3 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.8rem);
    line-height: 1;
  }

  .tool-line p:last-child {
    max-width: 780px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .tool-line span {
    font-weight: 700;
    color: var(--accent);
  }

  .principle-section {
    display: grid;
    grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1fr);
    gap: clamp(28px, 6vw, 88px);
    align-items: end;
    padding: clamp(64px, 10vw, 124px) clamp(20px, 5vw, 72px);
    background: var(--surface);
  }

  .principle-section > p {
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.2rem, 2.4vw, 1.7rem);
    line-height: 1.45;
  }

  .latest-posts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    margin-bottom: 28px;
    background: rgb(100 112 134 / 0.16);
  }

  .latest-post {
    min-height: 260px;
    padding: 28px;
    background: rgb(255 255 255 / 0.74);
    transition:
      transform 180ms ease,
      background 180ms ease;
  }

  .latest-post:hover {
    transform: translateY(-3px);
    background: var(--surface);
  }

  .latest-post time {
    color: var(--clipboard-teal);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .latest-post h3 {
    margin: 18px 0 14px;
    font-size: 1.35rem;
    line-height: 1.18;
  }

  .latest-post p {
    margin: 0;
    color: var(--muted);
    font-size: 0.98rem;
  }

  @media (max-width: 920px) {
    .principle-section,
    .latest-posts {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: auto;
      align-items: stretch;
      flex-direction: column;
      background: #121821;
    }

    .hero::after {
      background: linear-gradient(180deg, transparent 0%, rgb(12 17 24 / 0.82) 92%);
    }

    .hero-image {
      position: relative;
      height: auto;
      aspect-ratio: 1487 / 1058;
      object-fit: contain;
      object-position: center;
      background: #121821;
    }

    .hero-copy {
      margin-top: -28px;
      padding-top: 0;
    }

    .hero h1 {
      font-size: clamp(2.4rem, 12vw, 3.3rem);
    }

    .tool-line {
      grid-template-columns: 1fr;
    }
  }
</style>
