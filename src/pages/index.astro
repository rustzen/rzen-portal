---
import { Image } from 'astro:assets';
import SiteLayout from '../layouts/SiteLayout.astro';
import Button from '../components/Button.astro';
import SafetyChip from '../components/SafetyChip.astro';
import heroImg from '../assets/zen-clear-hero.png';
import { product } from '../data/product';
import { getLocale, pick, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;

const icons: Record<string, string> = {
  scan: '<path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/><circle cx="12" cy="12" r="3.4" stroke="currentColor" stroke-width="1.9"/>',
  project:
    '<path d="M3 7a2 2 0 0 1 2-2h4l2 2.4h8a2 2 0 0 1 2 2V17a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round"/>',
  safety:
    '<path d="M12 3 5 6v5c0 4.2 2.9 7.6 7 9 4.1-1.4 7-4.8 7-9V6l-7-3Z" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>',
  restore:
    '<path d="M4 9a8 8 0 1 1-1.5 4.5" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/><path d="M4 4v5h5" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>',
};

const meta = [
  { k: 'Pro', kZh: 'Pro', v: product.purchase.price, vZh: product.purchase.price },
  { k: 'Devices', kZh: '设备', v: product.purchase.deviceLimit, vZh: '最多 3 台' },
  { k: 'Free', kZh: '免费', v: product.purchase.free, vZh: '免费扫描与预览' },
  { k: 'Upgrade', kZh: '升级', v: product.purchase.pro, vZh: 'Pro 解锁清理、恢复中心与定时扫描' },
];
---

<SiteLayout
  title={pick(locale, "Zen Clear — Reclaim disk space you can't see | Rustzen", 'Zen Clear — 找回你看不见的磁盘空间 | Rustzen')}
  description={pick(locale, product.description, product.descriptionZh)}
  locale={locale}
>
  <main class="landing">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-copy reveal">
        <p class="eyebrow">{pick(locale, product.eyebrow, product.eyebrowZh)}</p>
        <h1>{pick(locale, product.heroTitle, product.heroTitleZh)}</h1>
        <p class="lead">{pick(locale, product.description, product.descriptionZh)}</p>
        <div class="actions">
          <Button variant="primary" href={product.download.href}>
            {pick(locale, product.download.label, product.download.labelZh)}
          </Button>
          <Button variant="secondary" href={product.purchase.href} target="_blank" rel="noreferrer">
            {pick(locale, product.purchase.label, product.purchase.labelZh)}
          </Button>
        </div>
        <dl class="hero-meta glass-2" aria-label="Zen Clear Pro pricing and limits">
          {meta.map((m) => (
            <div>
              <dt>{pick(locale, m.k, m.kZh)}</dt>
              <dd>{pick(locale, m.v, m.vZh)}</dd>
            </div>
          ))}
        </dl>
        <p class="trust">{pick(locale, product.trust, product.trustZh)}</p>
      </div>

      <figure class="hero-media reveal">
        <div class="app-frame">
          <div class="dots" aria-hidden="true">
            <span class="tl-r"></span><span class="tl-y"></span><span class="tl-g"></span>
          </div>
          <Image src={heroImg} alt={product.image.alt} loading="eager" widths={[480, 768, 1024, 1536]} sizes="(max-width: 900px) 100vw, 56vw" />
        </div>
        <SafetyChip class="float-chip s1" level="safe" label={pick(locale, 'Safe', '安全')} />
        <SafetyChip class="float-chip s2" level="caution" label={pick(locale, 'Caution', '谨慎')} />
      </figure>
    </section>

    <!-- Problem -->
    <section class="problem" aria-labelledby="problem-title">
      <div class="head">
        <p class="eyebrow">{pick(locale, 'The hidden cost of dev', '开发数据的隐形成本')}</p>
        <h2 id="problem-title">{pick(locale, product.problemTitle, product.problemTitleZh)}</h2>
      </div>
      <div class="pills">
        {product.problem.map((p) => (
          <span class="pill"><b>{p.label}</b><i>{p.size}</i></span>
        ))}
      </div>
    </section>

    <!-- How it works -->
    <section class="steps" aria-labelledby="steps-title">
      <div class="head">
        <p class="eyebrow">{pick(locale, product.stepsTitle, product.stepsTitleZh)}</p>
        <h2 id="steps-title">{pick(locale, 'Scan. Understand. Clean safely.', '扫描 · 理解 · 安全清理。')}</h2>
      </div>
      <ol class="grid">
        {product.steps.map((s) => (
          <li class="glass step">
            <span class="num">{s.n}</span>
            <h3>{pick(locale, s.title, s.titleZh)}</h3>
            <p>{pick(locale, s.body, s.bodyZh)}</p>
          </li>
        ))}
      </ol>
    </section>

    <!-- Features -->
    <section class="features" id="features" aria-labelledby="features-title">
      <div class="head">
        <p class="eyebrow">{pick(locale, 'Why Zen Clear', '为什么选择 Zen Clear')}</p>
        <h2 id="features-title">{pick(locale, 'Built for developer machines.', '为开发者机器而生。')}</h2>
      </div>
      <div class="grid">
        {product.features.map((f) => (
          <article class="glass feature-card">
            <span class="ic" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" set:html={icons[f.icon]} />
            </span>
            <h3>{pick(locale, f.title, f.titleZh)}</h3>
            <p>{pick(locale, f.body, f.bodyZh)}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Safety showcase -->
    <section class="safety" aria-labelledby="safety-title">
      <div class="head">
        <p class="eyebrow">{pick(locale, 'Risk-grade everything', '为一切分级')}</p>
        <h2 id="safety-title">{pick(locale, "Know what's safe before you clean.", '清理之前，先知道什么是安全的。')}</h2>
      </div>
      <div class="grid">
        {product.safety.map((s) => (
          <div class="glass-2 safety-col">
            <SafetyChip level={s.level} label={pick(locale, s.title, s.titleZh)} />
            <h3>{pick(locale, s.title, s.titleZh)}</h3>
            <p>{pick(locale, s.body, s.bodyZh)}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing -->
    <section class="pricing" id="pricing" aria-labelledby="pricing-title">
      <div class="head">
        <p class="eyebrow">{pick(locale, 'Pricing', '价格')}</p>
        <h2 id="pricing-title">{pick(locale, product.pricingTitle, product.pricingTitleZh)}</h2>
      </div>
      <div class="grid">
        {product.pricing.map((plan) => (
          <article class:list={['glass', 'plan', { featured: plan.featured }]}>
            <header>
              <h3>{pick(locale, plan.name, plan.nameZh)}</h3>
              <p class="tagline">{pick(locale, plan.tagline, plan.taglineZh)}</p>
            </header>
            <p class="price"><span>{plan.price}</span><small>{pick(locale, plan.per ?? '/forever', plan.perZh ?? '/永久')}</small></p>
            <ul>
              {plan.features.map((feat, i) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m5 12 4 4L19 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>{pick(locale, feat, plan.featuresZh[i])}</span>
                </li>
              ))}
            </ul>
            <Button variant={plan.featured ? 'primary' : 'secondary'} href={plan.href}>{pick(locale, plan.cta, plan.ctaZh)}</Button>
          </article>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq" id="help" aria-labelledby="faq-title">
      <div class="head">
        <p class="eyebrow">{pick(locale, 'FAQ', '常见问题')}</p>
        <h2 id="faq-title">{pick(locale, product.faqTitle, product.faqTitleZh)}</h2>
      </div>
      <div class="faq-list">
        {product.faq.map((item) => (
          <details class="glass-2 faq-item">
            <summary>{pick(locale, item.q, item.qZh)}</summary>
            <p>{pick(locale, item.a, item.aZh)}</p>
          </details>
        ))}
      </div>
    </section>

  </main>
</SiteLayout>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(320px, 0.86fr) minmax(0, 1fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: center;
    padding: clamp(40px, 7vw, 96px) clamp(20px, 5vw, 72px) clamp(56px, 9vw, 120px);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -8%;
    right: -4%;
    width: 62%;
    height: 86%;
    background: radial-gradient(circle at 68% 28%, var(--ambient-a), transparent 60%);
    z-index: -1;
    pointer-events: none;
  }

  .hero-copy h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.6rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .hero-copy .lead {
    max-width: 560px;
    margin: 22px 0 0;
    color: var(--ink-2);
    font-size: clamp(1.05rem, 1.6vw, 1.22rem);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 30px;
    flex-wrap: wrap;
  }

  .hero-meta {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    max-width: 620px;
    margin: 26px 0 0;
    overflow: hidden;
    border-radius: var(--radius);
  }

  .hero-meta div {
    padding: 14px 16px;
  }

  .hero-meta dt {
    color: var(--ink-3);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-meta dd {
    margin: 6px 0 0;
    color: var(--ink);
    font-weight: 700;
    font-size: 0.96rem;
  }

  .trust {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 20px 0 0;
    color: var(--ink-3);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .hero-media {
    position: relative;
    margin: 0;
    transform: translateZ(0);
  }

  .app-frame {
    padding: 12px;
    border-radius: var(--radius-xl);
    background: var(--glass-1-bg);
    backdrop-filter: blur(var(--glass-1-blur)) saturate(180%);
    border: 1px solid var(--glass-1-border);
    box-shadow: 0 40px 90px rgba(31, 48, 86, 0.22), 0 1px 0 rgba(255, 255, 255, 0.7) inset;
    transition: transform var(--motion-base) var(--ease-standard),
      box-shadow var(--motion-base) var(--ease-standard);
  }

  .hero-media:hover .app-frame {
    transform: translateY(-4px);
    box-shadow: 0 50px 110px rgba(31, 48, 86, 0.26), 0 1px 0 rgba(255, 255, 255, 0.7) inset;
  }

  .app-frame .dots {
    display: flex;
    gap: 7px;
    padding: 2px 6px 12px;
  }

  .app-frame .dots span {
    width: 11px;
    height: 11px;
    border-radius: 999px;
  }

  .tl-r { background: #ff5f57; }
  .tl-y { background: #febc2e; }
  .tl-g { background: #28c840; }

  .app-frame :global(img) {
    width: 100%;
    border-radius: var(--radius-lg);
  }

  .float-chip {
    position: absolute;
    box-shadow: 0 10px 24px rgba(31, 48, 86, 0.16);
  }

  .float-chip.s1 { top: 16%; left: -22px; }
  .float-chip.s2 { bottom: 18%; right: -18px; }

  .problem,
  .steps,
  .features,
  .safety,
  .pricing,
  .faq {
    padding: clamp(48px, 7vw, 92px) clamp(20px, 5vw, 72px);
  }

  .head {
    max-width: 720px;
    margin-bottom: 34px;
  }

  .problem h2,
  .steps h2,
  .features h2,
  .safety h2,
  .pricing h2,
  .faq h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .pill {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 999px;
    background: var(--glass-2-bg);
    border: 1px solid var(--glass-2-border);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.92rem;
  }

  .pill i {
    font-style: normal;
    color: var(--brand-600);
    font-weight: 700;
  }

  .steps .grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, 1fr);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .step {
    padding: 28px;
  }

  .step .num {
    display: inline-block;
    margin-bottom: 14px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--brand-600);
    letter-spacing: 0.08em;
  }

  .step h3 {
    margin: 0 0 8px;
    font-size: 1.2rem;
    color: var(--ink);
  }

  .step p {
    margin: 0;
    color: var(--ink-2);
    font-size: 0.98rem;
  }

  .features .grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, 1fr);
  }

  .feature-card {
    padding: 26px;
  }

  .feature-card .ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    margin-bottom: 16px;
    background: color-mix(in srgb, var(--brand-600) 14%, transparent);
    color: var(--brand-600);
  }

  .feature-card h3 {
    margin: 0 0 8px;
    font-size: 1.2rem;
    color: var(--ink);
  }

  .feature-card p {
    margin: 0;
    color: var(--ink-2);
    font-size: 0.98rem;
  }

  .safety .grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, 1fr);
  }

  .safety-col {
    padding: 28px;
  }

  .safety-col h3 {
    margin: 16px 0 8px;
    font-size: 1.15rem;
    color: var(--ink);
  }

  .safety-col p {
    margin: 0;
    color: var(--ink-2);
  }

  .pricing .grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 360px));
    justify-content: center;
  }

  .plan {
    display: flex;
    flex-direction: column;
    padding: 30px;
  }

  .plan.featured {
    border-color: color-mix(in srgb, var(--brand-400) 55%, transparent);
    box-shadow: 0 30px 70px rgba(63, 127, 217, 0.18);
  }

  .plan header h3 {
    margin: 0;
    font-size: 1.25rem;
    color: var(--ink);
  }

  .plan .tagline {
    margin: 6px 0 0;
    color: var(--ink-3);
    font-size: 0.94rem;
  }

  .plan .price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin: 20px 0;
    color: var(--ink);
    font-size: 2.6rem;
    font-weight: 700;
    line-height: 1;
  }

  .plan .price small {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink-3);
  }

  .plan ul {
    flex: 1;
    display: grid;
    gap: 10px;
    margin: 0 0 24px;
    padding: 0;
    list-style: none;
  }

  .plan li {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink-2);
    font-size: 0.96rem;
  }

  .plan li svg {
    color: var(--brand-600);
    flex: 0 0 auto;
  }

  .faq-list {
    max-width: 820px;
    display: grid;
    gap: 12px;
  }

  .faq-item {
    padding: 4px 22px;
    border-radius: var(--radius);
  }

  .faq-item summary {
    padding: 16px 0;
    cursor: pointer;
    font-weight: 600;
    color: var(--ink);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    color: var(--brand-600);
    font-size: 1.4rem;
    font-weight: 400;
    transition: transform var(--motion-fast) var(--ease-standard);
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    margin: 0 0 18px;
    color: var(--ink-2);
  }

  @media (max-width: 900px) {
    .hero,
    .features .grid,
    .safety .grid,
    .steps .grid {
      grid-template-columns: 1fr;
    }
    .pricing .grid {
      grid-template-columns: 1fr;
    }
    .float-chip.s1 { left: 8px; }
    .float-chip.s2 { right: 8px; }
  }

  @media (max-width: 560px) {
    .hero-meta {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
