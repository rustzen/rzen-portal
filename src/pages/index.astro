---
import SiteLayout from '../layouts/SiteLayout.astro';
import { product } from '../data/product';
---

<SiteLayout title="Zen Clear | RustZen" description={product.description}>
  <main class={`landing ${product.accent}`}>
    <section class="hero">
      <div class="hero-copy reveal">
        <p class="eyebrow">{product.eyebrow}</p>
        <h1>{product.name}</h1>
        <p>{product.description}</p>
        <div class="actions">
          <a class="button primary" href={product.download.href}>
            {product.download.label}
          </a>
          <a class="button secondary" href={product.purchase.href}>
            {product.purchase.label}
          </a>
          <span>{product.purchase.price}</span>
        </div>
      </div>
      <figure class="hero-media reveal">
        <img src={product.image.src} alt={product.image.alt} loading="eager" />
      </figure>
    </section>

    <section class="capabilities" aria-labelledby="capabilities-title">
      <div>
        <p class="eyebrow">Capabilities</p>
        <h2 id="capabilities-title">What it does.</h2>
      </div>
      <ul>
        {product.highlights.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="proof">
      <p>{product.proof}</p>
    </section>
  </main>
</SiteLayout>

<style>
  .landing.clear {
    --page-accent: var(--clear-blue-deep);
    --page-accent-2: var(--clear-blue-mid);
    --page-panel: var(--clear-panel);
    --page-soft: rgb(211 231 253 / 0.72);
  }

  .hero {
    display: grid;
    min-height: calc(100svh - 67px);
    grid-template-columns: minmax(320px, 0.74fr) minmax(460px, 1.08fr);
    gap: clamp(32px, 7vw, 92px);
    align-items: center;
    padding: clamp(54px, 9vw, 128px) clamp(20px, 5vw, 72px);
    color: var(--charcoal);
    background:
      radial-gradient(circle at 78% 24%, var(--page-soft), transparent 36%),
      linear-gradient(135deg, #ffffff 0%, var(--page-panel) 58%, var(--paper) 100%);
  }

  .hero-copy h1 {
    max-width: 9ch;
    margin: 0;
    font-size: clamp(4rem, 10vw, 8.4rem);
    line-height: 0.9;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .hero-copy > p:not(.eyebrow) {
    max-width: 680px;
    margin: 28px 0 0;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 30px;
    flex-wrap: wrap;
  }

  .actions span {
    color: var(--muted);
    font-weight: 700;
  }

  .hero-media {
    margin: 0;
    transform: translateZ(0);
  }

  .hero-media img {
    width: min(100%, 920px);
    margin-left: auto;
    border-radius: 18px;
    box-shadow:
      0 30px 90px color-mix(in srgb, var(--page-accent) 20%, transparent),
      0 1px 0 rgb(255 255 255 / 0.9) inset;
    transition:
      transform 220ms ease,
      box-shadow 220ms ease;
  }

  .hero-media:hover img {
    transform: translateY(-4px);
    box-shadow:
      0 36px 110px color-mix(in srgb, var(--page-accent) 24%, transparent),
      0 1px 0 rgb(255 255 255 / 0.9) inset;
  }

  .capabilities {
    display: grid;
    grid-template-columns: minmax(260px, 0.7fr) minmax(0, 1fr);
    gap: clamp(28px, 6vw, 82px);
    padding: clamp(64px, 10vw, 124px) clamp(20px, 5vw, 72px);
    background: rgb(255 255 255 / 0.74);
  }

  .capabilities h2 {
    margin: 0;
    color: var(--charcoal);
    font-size: clamp(2.2rem, 5vw, 4.4rem);
    line-height: 1;
  }

  .capabilities ul {
    display: grid;
    gap: 1px;
    margin: 0;
    padding: 0;
    list-style: none;
    background: rgb(100 112 134 / 0.16);
  }

  .capabilities li {
    padding: 22px 0;
    color: var(--charcoal);
    background: rgb(255 255 255 / 0.88);
    font-size: clamp(1.1rem, 2vw, 1.45rem);
  }

  .proof {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: clamp(42px, 7vw, 78px) clamp(20px, 5vw, 72px);
    background: var(--page-panel);
  }

  .proof p {
    max-width: 760px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.45rem);
  }

  @media (max-width: 900px) {
    .hero,
    .capabilities {
      grid-template-columns: 1fr;
    }

    .proof {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
