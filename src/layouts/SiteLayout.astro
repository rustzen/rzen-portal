---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'RustZen',
  description = 'Zen Clear — a native macOS cleanup app for developers.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="RustZen home">
        <img class="brand-mark" src="/rustzen-mark.svg" alt="" width="32" height="32" />
        <span class="brand-word">RustZen</span>
      </a>
    </header>
    <slot />
    <footer class="site-footer">
      <p>RustZen builds Zen Clear for local macOS work.</p>
    </footer>
  </body>
</html>
